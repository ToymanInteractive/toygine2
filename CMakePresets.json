    "testPresets": [
        {
            "name": "default-debug",
            "hidden": true,
            "output": {
                "shortProgress": true,
                "verbosity": "default",
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": true,
                "jobs": 0
            },
            "configuration": "Debug"
        },
        {
            "name": "default-release",
            "hidden": true,
            "output": {
                "shortProgress": true,
                "verbosity": "default",
                "outputOnFailure": true
            },
            "execution": {
                "stopOnFailure": true,
                "jobs": 0
            },
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "linux-ninja-release",
            "configurePreset": "linux-ninja-release",
            "inherits": "default-release"
        },
        {
            "name": "macos-ninja-release",
