            "inherits": "default-debug",
            "execution": {
                "stopOnFailure": true
            }
        },
        {
            "name": "linux-ninja-debug",
            "configurePreset": "linux-ninja-debug",
            "inherits": "default-debug"
        },
        {
            "name": "linux-ninja-tests-coverage",
            "configurePreset": "linux-ninja-tests-coverage",
            "inherits": "linux-ninja-debug",
            "output": {
                "shortProgress": true,
                "verbosity": "default",
                "outputOnFailure": true,
                "outputJUnitFile": "${sourceDir}/out/junit/${presetName}.xml"
            }
        }
