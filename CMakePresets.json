                "TOYGINE_BUILD_BENCHMARKS": "ON",
                "TOYGINE_BUILD_SAMPLES": "ON",
                "TOYGINE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "gba-ninja-release",
            "displayName": "Nintendo GBA release",
            "description": "ToyGine 2 GBA Ninja Release Build",
