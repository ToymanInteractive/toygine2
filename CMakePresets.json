{
    "version": 10,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 31,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "release-binary-dir",
            "hidden": true,
            "binaryDir": "${sourceDir}/out/build/${presetName}"
        },
        {
            "name": "base-release",
            "inherits": "release-binary-dir",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "PACKAGE_FILE_NAME": "$env{BUILD_FILE_NAME}",
                "PACKAGE_NAME_SUFFIX": "$env{BUILD_NAME_SUFFIX}",
                "TOYGINE_BUILD_BENCHMARKS": "OFF",
                "TOYGINE_BUILD_SAMPLES": "OFF",
                "TOYGINE_BUILD_TESTS": "OFF",
                "ENABLE_PUBLIC_RELEASE": "$env{ENABLE_PUBLIC_RELEASE}",
                "ENABLE_PCH": "OFF"
            }
        },
        {
            "name": "type-debug",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "type-relwithdebinfo",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "platform-macos-xcode",
            "hidden": true,
            "generator": "Xcode"
        },
        {
            "name": "platform-windows-x64",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            }
        },
        {
            "name": "platform-windows-x86",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "Win32",
                "strategy": "set"
            }
        },
        {
            "name": "platform-gba",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/GBA.cmake",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Nintendo GBA"
            }
        },
        {
            "name": "platform-nds",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/NDS.cmake",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Nintendo DS"
            }
        },
        {
            "name": "platform-3ds",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/3DS.cmake",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Nintendo 3DS"
            }
        },
        {
            "name": "platform-switch",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/Switch.cmake",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Nintendo Switch"
            }
        },
        {
            "name": "platform-gamecube",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/GameCube.cmake",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Nintendo GameCube"
            }
        },
        {
            "name": "platform-wii",
            "hidden": true,
            "toolchainFile": "$env{DEVKITPRO}/cmake/Wii.cmake",
            "cacheVariables": {
                "TOYGINE_TARGET_PLATFORM": "Nintendo Wii"
            }
        },
        {
            "name": "linux-ninja-release",
            "displayName": "Linux Ninja release",
            "description": "ToyGine 2 Linux Ninja Release Build",
            "inherits": ["type-relwithdebinfo", "base-release"],
            "cacheVariables": {
                "TOYGINE_BUILD_BENCHMARKS": "ON",
                "TOYGINE_BUILD_SAMPLES": "ON",
                "TOYGINE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "macos-ninja-release",
            "displayName": "macOS Ninja release",
            "description": "ToyGine 2 MacOS Ninja Release Build",
