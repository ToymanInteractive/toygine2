        },
        {
            "name": "nds-ninja-release",
            "displayName": "Nintendo DS release",
            "description": "ToyGine 2 NDS Ninja Release Build",
            "inherits": ["platform-nds", "type-relwithdebinfo", "base-release"],
            "cacheVariables": {
                "TOYGINE_BUILD_BENCHMARKS": "ON",
                "TOYGINE_BUILD_SAMPLES": "OFF",
                "TOYGINE_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "3ds-ninja-release",
            "displayName": "Nintendo 3DS release",
            "description": "ToyGine 2 3DS Ninja Release Build",
