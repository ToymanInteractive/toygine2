            "name": "linux-ninja-tests-coverage",
            "displayName": "Linux Ninja tests coverage",
            "description": "ToyGine 2 Linux Ninja Test Coverage",
            "inherits": "linux-ninja-debug",
            "cacheVariables": {
                "TOYGINE_BUILD_BENCHMARKS": "OFF",
                "TOYGINE_BUILD_SAMPLES": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default-debug",
            "hidden": true,
            "configuration": "Debug"
        },
        {
            "name": "default-release",
            "hidden": true,
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "linux-ninja-release",
