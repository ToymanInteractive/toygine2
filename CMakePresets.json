            }
        },
        {
            "name": "wii-ninja-release",
            "displayName": "Nintendo Wii release",
            "description": "ToyGine 2 Wii Ninja Release Build",
            "inherits": ["platform-wii", "type-relwithdebinfo", "base-release"],
            "cacheVariables": {
