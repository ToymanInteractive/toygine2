using std::int16_t;
using std::int32_t;
using std::int64_t;
using std::int8_t;
using std::uint16_t;
using std::uint32_t;
using std::uint64_t;
using std::uint8_t;

// (lvl 1)               Containers library https://en.cppreference.com/w/cpp/container.html

// https://en.cppreference.com/w/cpp/container/array.html
using std::array;

// (lvl 1)                 Iterator library https://en.cppreference.com/w/cpp/iterator.html

// https://en.cppreference.com/w/cpp/iterator/size.html
using std::size;

// (lvl 1)                  Utility library https://en.cppreference.com/w/cpp/utility.html

// https://en.cppreference.com/w/cpp/utility/compare/strong_ordering.html
using std::strong_ordering;

// (lvl 2)                 Bit manipulation https://en.cppreference.com/w/cpp/utility/bit.html

// https://en.cppreference.com/w/cpp/numeric/bit_cast.html
using std::bit_cast;

// (lvl 2) Type support (basic types, RTTI) https://en.cppreference.com/w/cpp/utility/rtti.html

// https://en.cppreference.com/w/cpp/types/nullptr_t.html
using std::nullptr_t;

// https://en.cppreference.com/cpp/types/byte
using std::byte;

// https://en.cppreference.com/w/cpp/types/numeric_limits.html
using std::numeric_limits;

// (lvl 1).         Metaprogramming library https://en.cppreference.com/w/cpp/meta.html

// https://en.cppreference.com/w/cpp/types/type_identity.html
using std::type_identity_t;

// (lvl 1).                 Strings library https://en.cppreference.com/w/cpp/string.html

// https://en.cppreference.com/w/cpp/string/char_traits.html
using std::char_traits;

#undef validate
#undef validate_message

#ifdef _DEBUG

/*!
  \def validate(expression)
  \brief When \c _DEBUG is defined: expands to \c assert(expression).

  Evaluates \a expression and triggers an assertion failure (via \c toy::assertion::assertion) if it is false.
  When \c _DEBUG is not defined, the other definition applies: expands to \c (expression) (evaluated, no check).

  \param expression Boolean expression to check. Prefer side-effect-free.

  \sa validate_message, assert
*/
#define validate(expression) assert(expression)

/*!
  \def validate_message(expression, message)
  \brief When \c _DEBUG is defined: expands to \c assert_message(expression, message).

  Same as \c validate but passes \a message to the assertion handler for a clearer failure report. When \c _DEBUG is not
  defined, expands to \c (expression); \a message is unused.

  \param expression Boolean expression to check. Prefer side-effect-free.
  \param message    A custom error message to display on assertion failure. Must be a C string literal.

  \sa validate, assert_message
*/
#define validate_message(expression, message) assert_message(expression, message)

#else

/*!
  \def validate(expression)
  \brief When \c _DEBUG is not defined: expands to \c (expression).

  The expression is evaluated but the result is discarded; no assertion is performed. Use for checks that are
  expensive or only needed in debug; the compiler may optimize away the evaluation if the result is unused.

  \param expression Boolean expression to check. Prefer side-effect-free. (evaluated, result discarded)

  \sa validate_message
*/
#define validate(expression)                  (expression)

/*!
  \def validate_message(expression, message)
  \brief When \c _DEBUG is not defined: expands to \c (expression).

  Same as \c validate; \a message is not used. The expression is evaluated, result discarded, no assertion.

  \param expression Boolean expression to check. Prefer side-effect-free. (evaluated, result discarded)
  \param message    The custom error message (ignored in release builds).

  \sa validate
*/
#define validate_message(expression, message) (expression)

#endif

#undef TOY_CONFIG_DEBUG_MEMORY
#if defined(_DEBUG) && !defined(FORCE_NOT_DEBUG_MEMORY)
#define TOY_CONFIG_DEBUG_MEMORY
#endif // defined(_DEBUG) && !defined(FORCE_NOT_DEBUG_MEMORY)

} // namespace toy

