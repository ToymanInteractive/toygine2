/*!
  \file   core.hpp
  \brief  Umbrella header for the engine core module.

  Defines the public core surface: platform, assertions, string utilities, output string stream, callbacks pool, fixed
  strings and vectors, hashing, formatting, and general utilities.

  \note Include this header only; do not include internal headers directly.
*/

#ifndef INCLUDE_CORE_HPP_
#define INCLUDE_CORE_HPP_

